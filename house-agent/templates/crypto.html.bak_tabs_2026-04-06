<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>House Crypto Control</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 24px;
      background: #111;
      color: #eee;
    }
    h1, h2 {
      margin-top: 0;
    }
    .card {
      background: #1b1b1b;
      border: 1px solid #333;
      border-radius: 10px;
      padding: 16px;
      margin-bottom: 16px;
    }
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 12px;
      margin-bottom: 16px;
    }
    .stat {
      background: #1b1b1b;
      border: 1px solid #333;
      border-radius: 10px;
      padding: 16px;
    }
    .stat .label {
      color: #aaa;
      font-size: 13px;
      margin-bottom: 8px;
    }
    .stat .value {
      font-size: 26px;
      font-weight: bold;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 12px;
    }
    th, td {
      padding: 10px;
      border-bottom: 1px solid #333;
      text-align: left;
      vertical-align: top;
    }
    tr.locked-row {
      background: rgba(255, 200, 0, 0.06);
    }
    tr.zero-row {
      opacity: 0.75;
    }
    input, select, button {
      padding: 10px;
      margin: 4px 0;
      border-radius: 8px;
      border: 1px solid #444;
      background: #222;
      color: #eee;
    }
    button {
      cursor: pointer;
    }
    .row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }
    .muted {
      color: #aaa;
    }
    .pill {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 999px;
      border: 1px solid #444;
      font-size: 12px;
    }
    .pill.locked {
      border-color: #aa8844;
    }
    .pill.open {
      border-color: #3d6b4f;
    }
    pre {
      white-space: pre-wrap;
      word-break: break-word;
      background: #0d0d0d;
      padding: 10px;
      border-radius: 8px;
      border: 1px solid #222;
      min-height: 60px;
    }
    .toolbar {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }
  </style>
</head>
<body>
  <h1>House Crypto Control</h1>

  <div class="cards">
    <div class="stat">
      <div class="label">Total wallet value</div>
      <div class="value" id="stat-total">-</div>
    </div>
    <div class="stat">
      <div class="label">Locked value</div>
      <div class="value" id="stat-locked">-</div>
    </div>
    <div class="stat">
      <div class="label">Unlocked value</div>
      <div class="value" id="stat-unlocked">-</div>
    </div>
    <div class="stat">
      <div class="label">Assets</div>
      <div class="value" id="stat-assets">-</div>
    </div>
  </div>

  <div class="card">
    <h2>Portfolio</h2>
    <div class="toolbar">
      <input id="filter-symbol" type="text" placeholder="Filter symbol..." oninput="renderHoldings()">
      <label><input id="filter-locked" type="checkbox" onchange="renderHoldings()"> Locked only</label>
      <label><input id="filter-priced" type="checkbox" onchange="renderHoldings()"> Non-zero price only</label>
    </div>
    <div id="portfolio-summary" class="muted">Loading holdings...</div>
    <table id="holdings-table">
      <thead>
        <tr>
          <th>Symbol</th>
          <th>Amount</th>
          <th>EUR Price</th>
          <th>EUR Value</th>
          <th>Locked</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </div>

  <div class="card">
    <h2>Buy Preview</h2>
    <div class="row">
      <select id="buy-symbol"></select>
      <input id="buy-eur" type="number" step="0.01" min="0.01" placeholder="EUR amount">
      <button onclick="previewBuy()">Preview Buy</button>
    </div>
    <div class="muted" id="buy-market-info">Loading available EUR markets...</div>
  </div>

  <div class="card">
    <h2>Sell Preview</h2>
    <div class="row">
      <select id="sell-symbol"></select>
      <input id="sell-amount" type="number" step="0.00000001" min="0.00000001" placeholder="Asset amount">
      <button onclick="previewSell()">Preview Sell</button>
      <button onclick="sellAll()">Sell All</button>
    </div>
  </div>

  <div class="card">
    <h2>Latest Preview</h2>
    <pre id="preview-box">No preview yet.</pre>
    <div class="row">
      <button onclick="requestApproval()">Request Approval</button>
    </div>
  </div>

  <div class="card">
    <h2>Pending Approvals</h2>
    <pre id="approval-box">Loading...</pre>
  </div>

  <div class="card">
    <h2>Recent Previews</h2>
    <pre id="previews-box">Loading...</pre>
  </div>

  <script>
    let latestPreview = null;
    let latestHoldings = [];
    let latestBuyMarkets = [];

    async function fetchJson(url, options = {}) {
      const res = await fetch(url, options);
      const data = await res.json();
      if (!res.ok) {
        throw new Error(data.error || data.message || 'request failed');
      }
      return data;
    }

    function euro(v) {
      const n = Number(v || 0);
      return n.toFixed(2);
    }

    function fmt(v) {
      if (v === null || v === undefined || v === '') return '';
      return String(v);
    }

    function renderSummary() {
      const total = latestHoldings.reduce((s, x) => s + Number(x.eur_value || 0), 0);
      const locked = latestHoldings
        .filter(x => x.locked)
        .reduce((s, x) => s + Number(x.eur_value || 0), 0);
      const unlocked = total - locked;

      document.getElementById('stat-total').textContent = euro(total) + ' EUR';
      document.getElementById('stat-locked').textContent = euro(locked) + ' EUR';
      document.getElementById('stat-unlocked').textContent = euro(unlocked) + ' EUR';
      document.getElementById('stat-assets').textContent = String(latestHoldings.length);
    }

    function renderHoldings() {
      const tbody = document.querySelector('#holdings-table tbody');
      tbody.innerHTML = '';

      const q = document.getElementById('filter-symbol').value.trim().toUpperCase();
      const lockedOnly = document.getElementById('filter-locked').checked;
      const pricedOnly = document.getElementById('filter-priced').checked;

      let rows = [...latestHoldings];

      if (q) {
        rows = rows.filter(x => String(x.symbol || '').includes(q));
      }
      if (lockedOnly) {
        rows = rows.filter(x => !!x.locked);
      }
      if (pricedOnly) {
        rows = rows.filter(x => Number(x.eur_price || 0) > 0);
      }

      for (const item of rows) {
        const tr = document.createElement('tr');
        if (item.locked) tr.classList.add('locked-row');
        if (Number(item.eur_price || 0) === 0) tr.classList.add('zero-row');

        tr.innerHTML = `
          <td>${item.symbol}</td>
          <td>${fmt(item.amount)}</td>
          <td>${fmt(item.eur_price)}</td>
          <td>${fmt(item.eur_value)}</td>
          <td>${item.locked ? '<span class="pill locked">LOCKED</span>' : '<span class="pill open">OPEN</span>'}</td>
          <td>
            <button onclick="toggleLock('${item.symbol}', ${item.locked ? 'false' : 'true'})">
              ${item.locked ? 'Unlock' : 'Lock'}
            </button>
          </td>
        `;
        tbody.appendChild(tr);
      }

      document.getElementById('portfolio-summary').textContent =
        `Visible rows: ${rows.length} | Total assets: ${latestHoldings.length}`;
    }

    async function loadBuyMarkets() {
      const data = await fetchJson('/api/trade/markets');
      latestBuyMarkets = data.items || [];

      const buySelect = document.getElementById('buy-symbol');
      const current = buySelect.value;
      buySelect.innerHTML = '';

      for (const item of latestBuyMarkets) {
        const opt = document.createElement('option');
        opt.value = item.symbol;
        opt.textContent = item.symbol;
        buySelect.appendChild(opt);
      }

      if (current && [...buySelect.options].some(o => o.value === current)) {
        buySelect.value = current;
      } else if ([...buySelect.options].some(o => o.value === 'ETH')) {
        buySelect.value = 'ETH';
      }

      document.getElementById('buy-market-info').textContent =
        `Available EUR markets: ${latestBuyMarkets.length}`;
    }

    async function loadHoldings() {
      const data = await fetchJson('/api/trade/holdings');
      latestHoldings = data.holdings || [];

      const sellSelect = document.getElementById('sell-symbol');
      const previousSellValue = sellSelect.value;
      sellSelect.innerHTML = '';

      for (const item of latestHoldings) {
        const opt = document.createElement('option');
        opt.value = item.symbol;
        opt.textContent = item.symbol;
        sellSelect.appendChild(opt);
      }

      if (previousSellValue && [...sellSelect.options].some(o => o.value === previousSellValue)) {
        sellSelect.value = previousSellValue;
      }

      renderSummary();
      renderHoldings();
    }

    async function loadPendingApprovals() {
      const data = await fetchJson('/ai/approvals/pending');
      document.getElementById('approval-box').textContent = JSON.stringify(data, null, 2);
    }

    async function loadRecentPreviews() {
      const data = await fetchJson('/api/trade/previews?limit=10');
      document.getElementById('previews-box').textContent = JSON.stringify(data, null, 2);
    }

    function renderPreviewBox(data) {
      const preview = data.preview || {};
      const lines = [
        `status: ${data.status || ''}`,
        `preview_id: ${data.preview_id || ''}`,
        `side: ${preview.side || ''}`,
        `market: ${preview.market || ''}`,
        `estimated_amount: ${preview.estimated_amount || ''}`,
        `estimated_eur_total: ${preview.estimated_eur_total || ''}`,
        `current_price: ${preview.current_price || ''}`,
        `expires_in_seconds: ${data.expires_in_seconds || ''}`
      ];
      document.getElementById('preview-box').textContent = lines.join('\n');
    }

    async function previewBuy() {
      try {
        const symbol = document.getElementById('buy-symbol').value;
        const eurAmount = parseFloat(document.getElementById('buy-eur').value);

        const data = await fetchJson('/api/trade/preview', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            side: 'buy',
            symbol: symbol,
            eur_amount: eurAmount
          })
        });

        latestPreview = data;
        renderPreviewBox(data);
        await loadRecentPreviews();
      } catch (err) {
        document.getElementById('preview-box').textContent = 'Preview buy failed: ' + err.message;
      }
    }

    async function previewSell() {
      try {
        const symbol = document.getElementById('sell-symbol').value;
        const amount = parseFloat(document.getElementById('sell-amount').value);

        const data = await fetchJson('/api/trade/preview', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            side: 'sell',
            symbol: symbol,
            amount: amount
          })
        });

        latestPreview = data;
        renderPreviewBox(data);
        await loadRecentPreviews();
      } catch (err) {
        document.getElementById('preview-box').textContent = 'Preview sell failed: ' + err.message;
      }
    }

    async function sellAll() {
      try {
        const symbol = document.getElementById('sell-symbol').value;

        const data = await fetchJson('/api/trade/preview', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            side: 'sell',
            symbol: symbol,
            sell_all: true
          })
        });

        latestPreview = data;
        renderPreviewBox(data);
        await loadRecentPreviews();
      } catch (err) {
        document.getElementById('preview-box').textContent = 'Sell all preview failed: ' + err.message;
      }
    }

    async function requestApproval() {
      try {
        if (!latestPreview) {
          throw new Error('No preview available');
        }

        const previewId = latestPreview.preview_id;
        if (!previewId) {
          throw new Error('Preview ID not found');
        }

        const data = await fetchJson('/api/trade/request-approval', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            preview_id: previewId,
            requested_by: 'crypto_ui'
          })
        });

        document.getElementById('approval-box').textContent = JSON.stringify(data, null, 2);
        await loadPendingApprovals();
      } catch (err) {
        document.getElementById('approval-box').textContent = 'Request approval failed: ' + err.message;
      }
    }

    async function toggleLock(symbol, locked) {
      try {
        await fetchJson('/api/trade/lock', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            symbol: symbol,
            locked: locked,
            reason: locked ? 'manual_ui_lock' : 'manual_ui_unlock'
          })
        });
        await loadHoldings();
      } catch (err) {
        alert('Lock update failed: ' + err.message);
      }
    }

    async function refreshAll() {
      try { await loadBuyMarkets(); } catch (err) {}
      try { await loadHoldings(); } catch (err) {}
      try { await loadPendingApprovals(); } catch (err) {}
      try { await loadRecentPreviews(); } catch (err) {}
    }

    refreshAll();
    setInterval(refreshAll, 4000);
  </script>
</body>
</html>
