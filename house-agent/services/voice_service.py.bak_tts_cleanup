        "volume": resolved_volume,
        "lms_response": data,
    }


import time

def play_url_on_player(player_id: str, url: str, volume=None) -> dict:
    resolved_player_id = resolve_player_id(player_id)
    volume_result = set_player_volume(player_id, volume)

    stop_result = lms_request(resolved_player_id, ["stop"])

    load_result = lms_request(
        resolved_player_id,
        ["playlist", "play", url, "House AI"],
    )

    key = (player_id or "").strip().lower()

    if key in {"living", "livingarea"}:
        time.sleep(1.2)
        play_result = lms_request(resolved_player_id, ["play"])
        time.sleep(0.4)
        play_result_2 = lms_request(resolved_player_id, ["play"])
    else:
        time.sleep(0.35)
        play_result = lms_request(resolved_player_id, ["play"])
        play_result_2 = None

    return {
        "ok": True,
        "player_id": resolved_player_id,
        "volume": volume_result["volume"],
        "url": url,
        "lms_stop_response": stop_result,
        "lms_response": load_result,
        "lms_play_response": play_result,
        "lms_play_response_2": play_result_2,
    }

def say_text(text: str, player_id: str = "", volume=None) -> dict:
    audio = synthesize_wav(text)
    playback = play_url_on_player(player_id=player_id, url=audio["url"], volume=volume)

    return {
        "ok": True,
        "status": "ok",
        "text": audio["text"],
        "audio_file": audio["filename"],
        "audio_url": audio["url"],
        "player_id": playback["player_id"],
        "volume": playback["volume"],
        "lms_response": playback["lms_response"],
        "lms_stop_response": playback["lms_stop_response"],
        "lms_play_response": playback["lms_play_response"],
        "lms_play_response_2": playback["lms_play_response_2"],
    }


def announce_text(
    text: str,
    player_id: str = "",
    volume=None,
    prefix: str = "",
) -> dict:
    final_text = text.strip()
    if prefix:
        final_text = f"{prefix}. {final_text}"
    return say_text(final_text, player_id=player_id, volume=volume)
