def resolve_volume(volume=None) -> float:
    if volume is None or volume == "":
        return DEFAULT_VOLUME
    value = float(volume)
    if value < 0:
        value = 0
    if value > 100:
        value = 100
    return value


def _build_syn_config():
    kwargs = {}

    if PIPER_VOLUME:
        kwargs["volume"] = float(PIPER_VOLUME)
    if PIPER_LENGTH_SCALE:
        kwargs["length_scale"] = float(PIPER_LENGTH_SCALE)
    if PIPER_NOISE_SCALE:
        kwargs["noise_scale"] = float(PIPER_NOISE_SCALE)
    if PIPER_NOISE_W_SCALE:
        kwargs["noise_w_scale"] = float(PIPER_NOISE_W_SCALE)

    if kwargs:
        return SynthesisConfig(**kwargs)

    return None


def _get_voice() -> PiperVoice:
    global VOICE

    if VOICE is None:
        model_path = Path(PIPER_MODEL)
        if not model_path.exists():
            raise FileNotFoundError(f"Piper model not found: {PIPER_MODEL}")

        VOICE = PiperVoice.load(
            str(model_path),
            use_cuda=PIPER_USE_CUDA,
        )

    return VOICE


def synthesize_wav(text: str) -> dict:
    text = sanitize_text(text)
    if not text:
        raise ValueError("Text is empty")

    voice = _get_voice()
    syn_config = _build_syn_config()

    filename = f"{uuid.uuid4().hex}.wav"
    filepath = VOICE_DIR / filename

    kwargs = {}
    if syn_config is not None:
        kwargs["syn_config"] = syn_config
    if PIPER_SPEAKER:
        kwargs["speaker_id"] = int(PIPER_SPEAKER)

    chunks = chunk_text(text, max_chars=350)

    if len(chunks) == 1:
        with wave.open(str(filepath), "wb") as wav_file:
            voice.synthesize_wav(chunks[0], wav_file, **kwargs)
    else:
        part_files = []

        for i, chunk in enumerate(chunks):
            part_path = VOICE_DIR / f"{filepath.stem}_part{i}.wav"
            with wave.open(str(part_path), "wb") as wav_file:
                voice.synthesize_wav(chunk, wav_file, **kwargs)
            part_files.append(str(part_path))

        concat_wav_files(part_files, str(filepath))

        for part_file in part_files:
            try:
                Path(part_file).unlink()
            except Exception:
                pass

    if not filepath.exists():
        raise RuntimeError(f"Piper did not create output file: {filepath}")

    return {
        "filename": filename,
        "filepath": str(filepath),
        "url": f"{PUBLIC_BASE_URL}/voice/files/{filename}",
        "text": text,
    }


def lms_request(player_id, command_parts):
    payload = {
        "id": 1,
        "method": "slim.request",
        "params": [player_id, command_parts],
    }

    response = requests.post(
        f"http://{LMS_HOST}:{LMS_PORT}/jsonrpc.js",
        json=payload,
        timeout=10,
    )
    response.raise_for_status()
    return response.json()


def get_players():
    data = lms_request(0, ["players", "0", "50"])
    return (data.get("result", {}) or {}).get("players_loop", []) or []




