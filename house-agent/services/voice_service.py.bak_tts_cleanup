def normalize_wav_ffmpeg(src_path: str, dst_path: str) -> str:
    cmd = [
        "ffmpeg",
        "-y",
        "-i",
        src_path,
        "-ac", "1",
        "-ar", "22050",
        "-sample_fmt", "s16",
        dst_path,
    ]
    subprocess.run(
        cmd,
        check=True,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return dst_path


def ensure_standard_wav(wav_path: str) -> str:
    try:
        with wave.open(wav_path, "rb") as wf:
            channels = wf.getnchannels()
            sampwidth = wf.getsampwidth()
            framerate = wf.getframerate()

        if channels == 1 and sampwidth == 2 and framerate == 22050:
            return wav_path
    except Exception:
        pass

    fixed_path = str(Path(wav_path).with_name(Path(wav_path).stem + "_fixed.wav"))
    return normalize_wav_ffmpeg(wav_path, fixed_path)


def concat_wav_files(wav_paths: list[str], output_path: str) -> str:
    if not wav_paths:
        raise ValueError("No WAV files to concatenate")

    normalized_paths = []
    temp_fixed_paths = []

    for wav_path in wav_paths:
        normalized = ensure_standard_wav(wav_path)
        normalized_paths.append(normalized)
        if normalized != wav_path:
            temp_fixed_paths.append(normalized)

    try:
        with wave.open(normalized_paths[0], "rb") as first:
            nchannels = first.getnchannels()
            sampwidth = first.getsampwidth()
            framerate = first.getframerate()
            comptype = first.getcomptype()
            compname = first.getcompname()

        with wave.open(output_path, "wb") as out:
            out.setnchannels(nchannels)
            out.setsampwidth(sampwidth)
            out.setframerate(framerate)
            out.setcomptype(comptype, compname)

            ref_format = (nchannels, sampwidth, framerate, comptype)

            for wav_path in normalized_paths:
                with wave.open(wav_path, "rb") as wf:
                    current_format = (
                        wf.getnchannels(),
                        wf.getsampwidth(),
                        wf.getframerate(),
                        wf.getcomptype(),
                    )
                    if current_format != ref_format:
                        raise ValueError(f"WAV format mismatch after normalization for {wav_path}")
                    out.writeframes(wf.readframes(wf.getnframes()))

        return output_path

    finally:
        for temp_path in temp_fixed_paths:
            try:
                Path(temp_path).unlink()
            except Exception:
                pass


def sanitize_text(text: str) -> str:
    return " ".join(str(text).split())


def resolve_player_id(player_id: str = "") -> str:
    key = (player_id or "").strip().lower()
    if not key:
        return DEFAULT_PLAYER_ID
    return PLAYER_ALIASES.get(key, player_id)

