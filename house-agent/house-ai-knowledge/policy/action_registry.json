    "music_party_start": {
      "category": "cat3",
      "description": "Verify living and bass players are online, enable living and bass routes, then start party scene.",
      "confirmation_required": true,
      "steps": [
        {
          "action": "ensure_host_online",
          "control_name": "picore_livingroom_power_switch",
          "host": "audio-living-node.local",
          "verify": {
            "method": "ping",
            "timeout_seconds": 2,
            "retries": 2
          },
          "power_on_wait_seconds": 30
        },
        {
          "action": "ensure_host_online",
          "control_name": "picore_bassroom_power_switch",
          "host": "audio-bass-node.local",
          "verify": {
            "method": "ping",
            "timeout_seconds": 2,
            "retries": 2
          },
          "power_on_wait_seconds": 12
        },
        {
          "action": "ensure_on",
          "control_name": "picore_livingroom_route_switch"
        },
        {
          "action": "ensure_on",
          "control_name": "picore_storageroom_route_switch"
        },
