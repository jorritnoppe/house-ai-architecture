        {
          "action": "ensure_on",
          "control_name": "picore_wcroom_route_switch"
        },
        {
          "action": "press",
          "control_name": "wcroom_audio_start_scene_button"
        }
      ]
    },
    "music_wc_night_start": {
      "category": "cat2",
      "description": "Verify WC PiCore is online, enable route, then start WC night playback scene.",
      "confirmation_required": false,
      "steps": [
        {
          "action": "ensure_host_online",
          "control_name": "picore_toiletroom_power_switch",
          "host": "audio-toilet-node.local",
          "verify": {
            "method": "ping",
            "timeout_seconds": 2,
            "retries": 2
          },
          "power_on_wait_seconds": 30
        },
        {
          "action": "ensure_on",
          "control_name": "picore_wcroom_route_switch"
