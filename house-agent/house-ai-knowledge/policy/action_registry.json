{
  "actions": {
    "music_bathroom_start": {
      "category": "cat1",
      "description": "Verify bathroom PiCore is online, power it on if needed, then start bathroom playback scene.",
      "confirmation_required": false,
      "steps": [
        {
          "action": "ensure_host_online",
          "control_name": "picore_bathroom_power_switch",
          "host": "audio-bathroom-node.local",
          "verify": {
            "method": "ping",
            "timeout_seconds": 2,
            "retries": 2
          },
          "power_on_wait_seconds": 60
        },
        {
          "action": "press",
          "control_name": "bathroom_audio_start_scene_button"
        }
      ]
    },
    "music_bathroom_stop": {
      "category": "cat1",
      "description": "Stop bathroom playback scene.",
      "confirmation_required": false,
      "steps": [
        {
          "action": "press",
          "control_name": "bathroom_audio_stop_scene_button"
        }
      ]
    },
    "music_living_start": {
      "category": "cat1",
      "description": "Verify living room PiCore is online, enable route, then start living room playback scene.",
      "confirmation_required": false,
      "steps": [
        {
          "action": "ensure_host_online",
          "control_name": "picore_livingroom_power_switch",
          "host": "audio-living-node.local",
          "verify": {
            "method": "ping",
            "timeout_seconds": 2,
            "retries": 2
          },
          "power_on_wait_seconds": 30
        },
        {
          "action": "ensure_on",
          "control_name": "picore_livingroom_route_switch"
        },
        {
          "action": "press",
          "control_name": "livingroom_audio_start_scene_button"
        }
      ]
    },
    "music_living_stop": {
      "category": "cat1",
      "description": "Stop living room playback scene and release route.",
      "confirmation_required": false,
      "steps": [
        {
          "action": "press",
          "control_name": "livingroom_audio_stop_scene_button"
        }
      ],
      "cleanup_steps": [
        {
          "action": "ensure_off",
          "control_name": "picore_livingroom_route_switch"
        }
      ]
    },
    "music_wc_start": {
